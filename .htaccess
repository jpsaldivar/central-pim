Options -Indexes

<IfModule mod_rewrite.c>
    Options +FollowSymlinks
    RewriteEngine On

    # Archivos y carpetas reales pasan directo (css, imágenes, etc.)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Todo lo demás va al index.php raíz (que carga public/index.php)
    RewriteRule ^(.*)$ index.php [L,QSA]
</IfModule>
